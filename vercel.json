{
    "redirects": [
        {
            "source": "/:path*",
            "has": [{ "type": "host", "value": "orion-skills.danmercede.com" }],
            "destination": "https://www.danmercede.com/works/orion-skills/:path*",
            "permanent": true
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}
